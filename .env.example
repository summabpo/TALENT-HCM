# ─── Database (AWS RDS) ───────────────────────────────────────────────────────
TALENT_DB_NAME=db_talent
TALENT_DB_USER=talent_user
TALENT_DB_PASSWORD=talent_password
TALENT_DB_HOST=talent-db.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
TALENT_DB_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
# Docker service name in production, host.docker.internal to share with Nomiweb
REDIS_URL=redis://redis:6379/1

# ─── Django ───────────────────────────────────────────────────────────────────
# Must match Nomiweb's SECRET_KEY for session compatibility
DJANGO_SECRET_KEY=change-me-use-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=talent.nomiweb.co
DJANGO_SETTINGS_MODULE=config.settings.prod

# ─── Session (must match Nomiweb exactly) ─────────────────────────────────────
SESSION_COOKIE_DOMAIN=.nomiweb.co
SESSION_COOKIE_NAME=nomiweb_session

# ─── CORS (React SPA) ─────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://talent.nomiweb.co

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/2

# ─── File storage ─────────────────────────────────────────────────────────────
MEDIA_ROOT=/app/media/

# ─── Monitoring (optional) ────────────────────────────────────────────────────
SENTRY_DSN=
